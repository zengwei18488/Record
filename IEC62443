#!/bin/bash
# Debian 12 IEC 62443 Hardening Script

# 2. Configure Password Complexity (IEC 62443 compliant)
# minlen=12, minclass=4 (Upper, Lower, Digit, Special)
CONF_PW="/etc/security/pwquality.conf"
sudo sed -i 's/^# minlen =.*/minlen = 12/' $CONF_PW
sudo sed -i 's/^# minclass =.*/minclass = 4/' $CONF_PW
sudo sed -i 's/^# retry =.*/retry = 3/' $CONF_PW

# 3. Add Account Lockout (Prevent Brute Force)
# Lock for 30 mins after 5 failed attempts
AUTH_PAM="/etc/pam.d/common-auth"
if ! grep -q "pam_faillock.so" "$AUTH_PAM"; then
    sudo sed -i '1i auth requisite pam_faillock.so preauth' "$AUTH_PAM"
    echo "auth [default=die] pam_faillock.so authfail" | sudo tee -a "$AUTH_PAM"
    echo "auth sufficient pam_faillock.so authsucc" | sudo tee -a "$AUTH_PAM"
fi

# 4. Ensure Auth logging is active
sudo systemctl enable --now rsyslog
echo "auth,authpriv.*    /var/log/auth.log" | sudo tee /etc/rsyslog.d/audit.conf
sudo systemctl restart rsyslog

echo "Debian 12 Hardening Complete."


