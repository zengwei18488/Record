#!/bin/bash

# 1. SSH 登录前后的警告 (适用于所有终端)
echo "[1/3] Setting up SSH/Terminal banners..."
BANNER_PATH="/etc/issue.net"
cat <<EOF | sudo tee $BANNER_PATH /etc/motd
*************************************************************************
* WARNING: This system is for authorized users only.                    *
* Unauthorized access is strictly prohibited.                           *
* All activities on this system are monitored and recorded.             *
*************************************************************************
EOF

# 配置 SSH 在登录前显示该文件
sudo sed -i 's|^#\?Banner.*|Banner /etc/issue.net|' /etc/ssh/sshd_config
sudo systemctl restart ssh

# 2. 如果你使用的是 LXDM (HDMI 界面)
if [ -f /etc/lxdm/lxdm.conf ]; then
    echo "[2/3] Configuring LXDM login options..."
    # 隐藏用户列表 (合规要求)
    sudo sed -i 's/^#\? \?disable_user_list=.*/disable_user_list=1/' /etc/lxdm/lxdm.conf
    # 注意：LXDM 原生不支持在界面上显示超长文字 Banner，
    # 通常做法是修改登录背景图或使用 LightDM 代替。
fi

# 3. 强制新用户组权限 (保留你的 adduser 配置)
echo "[3/3] Updating adduser defaults..."
sudo sed -i "s/#EXTRA_GROUPS/EXTRA_GROUPS/; s/#ADD_EXTRA_GROUPS/ADD_EXTRA_GROUPS/" /etc/adduser.conf

echo "Banner configuration complete."
